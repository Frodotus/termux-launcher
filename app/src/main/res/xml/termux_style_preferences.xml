<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="termux_background"
        app:title="@string/termux_background_header">

        <SwitchPreferenceCompat
            app:key="use_system_wallpaper"
            app:title="@string/termux_use_system_wallpaper_title"
            app:summaryOn="@string/termux_use_system_wallpaper_on"
            app:summaryOff="@string/termux_use_system_wallpaper_off" />
    </PreferenceCategory>

    <PreferenceCategory
        app:key="termux_terminal_background"
        app:title="@string/termux_terminal_background_header">

        <androidx.preference.SeekBarPreference
            app:key="terminal_background_opacity"
            app:title="@string/termux_terminal_background_opacity_title"
            app:summary="@string/termux_terminal_background_opacity_summary"
            android:min="0"
            android:max="100"
            android:defaultValue="100"
            app:showSeekBarValue="true" />

        <SwitchPreferenceCompat
            app:key="terminal_material_tint_enabled"
            app:title="@string/termux_terminal_material_tint_enabled_title"
            app:summaryOn="@string/termux_terminal_material_tint_enabled_on"
            app:summaryOff="@string/termux_terminal_material_tint_enabled_off" />

    </PreferenceCategory>

    <PreferenceCategory
        app:key="termux_extrakeys_appsbar"
        app:title="@string/termux_extrakeys_appsbar_header">

        <androidx.preference.SeekBarPreference
            app:key="extrakeys_blur_radius"
            app:title="@string/termux_extrakeys_blur_radius_title"
            app:summary="@string/termux_extrakeys_blur_radius_summary"
            android:min="0"
            android:max="30"
            android:defaultValue="10"
            app:showSeekBarValue="true" />

        <androidx.preference.SeekBarPreference
            app:key="app_bar_opacity"
            app:title="@string/termux_app_bar_opacity_title"
            app:summary="@string/termux_app_bar_opacity_summary"
            android:min="0"
            android:max="100"
            android:defaultValue="50"
            app:showSeekBarValue="true" />

        <SwitchPreferenceCompat
            app:key="accessory_material_tint_enabled"
            app:title="@string/termux_accessory_material_tint_enabled_title"
            app:summaryOn="@string/termux_accessory_material_tint_enabled_on"
            app:summaryOff="@string/termux_accessory_material_tint_enabled_off" />
    </PreferenceCategory>

    <PreferenceCategory
        app:key="termux_sessions"
        app:title="@string/termux_sessions_header">

        <androidx.preference.SeekBarPreference
            app:key="sessions_opacity"
            app:title="@string/termux_sessions_opacity_title"
            app:summary="@string/termux_sessions_opacity_summary"
            android:min="0"
            android:max="100"
            android:defaultValue="50"
            app:showSeekBarValue="true" />
    </PreferenceCategory>

</PreferenceScreen>
